# Base URL of the API. Defaults to http://localhost:3000.
VITE_API_BASE_URL=http://localhost:3000

# OIDC provider (e.g. https://keycloak.example.com/realms/my-realm).
# When set, OIDC login is enabled and the dev User ID field is hidden.
VITE_OIDC_AUTHORITY=https://keycloak.jtektrnd.net/realms/jtekt
VITE_OIDC_CLIENT_ID=public
